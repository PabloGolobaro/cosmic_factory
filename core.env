# ----------------------------
# Kafka (core-инфраструктура)
# ----------------------------
# Используется в docker-compose для Kafka и Kafka UI.
# Подключается через --env-file core.env в Taskfile.

# Порты
KAFKA_EXTERNAL_PORT=9092
KAFKA_INTERNAL_PORT=29092
KAFKA_CONTROLLER_PORT=29093
KAFKA_UI_PORT=8090

# Версии Docker-образов
KAFKA_IMAGE=confluentinc/cp-kafka:8.2.0
KAFKA_UI_IMAGE=ghcr.io/kafbat/kafka-ui:v1.5.0
